# Секреты и настройки окружения (КРИТИЧЕСКИ ВАЖНО)
.env

# Виртуальное окружение Python
venv/
.venv/
env/
ENV/

# Локальная база данных SQLite
*.sqlite3

# Кэш Python и компилированный байт-код
__pycache__/
*.pyc
*.pyo
*.pyd

# Кэш тестов (pytest) и отчеты о покрытии
.pytest_cache/
.coverage
htmlcov/

# Логи работы бота
*.log

# Настройки IDE (VS Code, PyCharm)
.vscode/
.idea/
*.swp
# Playwright automation
automation-test/.venv/
automation-test/__pycache__/
automation-test/.pytest_cache/
automation-test/pay_test/__pycache__/
automation-test/failure.png
automation-test/test-results/
automation-test/playwright-report/
